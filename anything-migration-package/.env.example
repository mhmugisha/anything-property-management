# =============================================================================
# ANYTHING PROPERTY MANAGEMENT — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# Get this from your Neon dashboard: https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# AUTHENTICATION (Required)
# AUTH_SECRET: A random secret string used to sign session tokens.
# Your generated secret (keep this private!):
# 32410c33bf6bd1068428911bba534e863561d57ad595d45e464336ee97731086
#
# AUTH_URL: The full URL of your deployed app (no trailing slash)
# -----------------------------------------------------------------------------
AUTH_SECRET=32410c33bf6bd1068428911bba534e863561d57ad595d45e464336ee97731086
AUTH_URL=https://your-app-name.vercel.app

# -----------------------------------------------------------------------------
# APP ENVIRONMENT
# Set to PRODUCTION for live, DEVELOPMENT for local dev
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS (Required if using payment features)
# Get these from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# -----------------------------------------------------------------------------
# FILE UPLOADS — UPLOADCARE (Required if using file/image uploads)
# Get these from: https://uploadcare.com/dashboard/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY=YOUR_UPLOADCARE_PUBLIC_KEY

# -----------------------------------------------------------------------------
# GOOGLE MAPS (Optional — used for property location features)
# Get from: https://console.cloud.google.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# CORS (Optional — only needed if mobile app calls web API from different domain)
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://your-mobile-app.com,https://your-web-app.com
